# ──────────────────────────────────────────────────────────────
# ALZ Spoke Networking & Shared Services – Variable Definitions
# ──────────────────────────────────────────────────────────────
# This file documents every root-level input variable with its
# type, defaults, and key nested attributes.  Uncomment and fill
# in the sections you need.
#
# For a working deployment with all features enabled, see
# examples/full/terraform.tfvars.
# ──────────────────────────────────────────────────────────────

# ─── Global ──────────────────────────────────────────────────

# (Required) Azure region for all resources.
# Changing this forces recreation of all resources.
location = "southeastasia"

# (Optional) Controls whether telemetry is enabled for all AVM
# modules deployed by this pattern. Default: true
# enable_telemetry = false

# (Optional) Common tags applied to every taggable resource.
# Per-resource tags are merged on top. Default: {}
tags = {
  Environment = "Production"
  ManagedBy   = "Terraform"
}

# ─── Resource Groups ────────────────────────────────────────

# (Required) At least one resource group is needed.
# Map key is a reference key used by other variables (resource_group_key).
resource_groups = {
  rg_networking = {
    name = "rg-spoke-networking"
    # location = "southeastasia"   # defaults to var.location
    # tags     = {}                # merged with var.tags
  }
}

# ─── Log Analytics Workspace ────────────────────────────────

# (Optional) Bring-your-own Log Analytics workspace.
# When set, the pattern skips creation of a workspace and uses this workspace
# as the default for diagnostic_settings.  Default: null
# byo_log_analytics_workspace = {
#   resource_id = "/subscriptions/.../providers/Microsoft.OperationalInsights/workspaces/..."
#   location    = "southeastasia"
# }

# (Required when byo_log_analytics_workspace is null)
# Configuration for the pattern-managed workspace.
log_analytics_workspace_configuration = {
  name               = "law-shared-services"
  resource_group_key = "rg_networking"
  # location         = "southeastasia"        # defaults to var.location
  # sku              = "PerGB2018"            # default
  # retention_in_days = 30                    # default
  # tags             = {}

  # role_assignments = {
  #   ra_reader = {
  #     role_definition_id_or_name = "Log Analytics Reader"
  #     managed_identity_key       = "mi_app"    # XOR principal_id / assign_to_caller
  #   }
  # }
  # private_endpoints   = { ... }
  # diagnostic_settings = { ... }
}

# ─── Network Security Groups ────────────────────────────────

# (Optional) Map of NSGs.  security_rules = {} means only Azure default rules.
# Default: {}
# network_security_groups = {
#   nsg_app = {
#     name               = "nsg-app-subnet"
#     resource_group_key = "rg_networking"
#     # location         = "southeastasia"
#     security_rules = {
#       allow_https = {
#         name                       = "AllowHTTPS"
#         priority                   = 100
#         direction                  = "Inbound"
#         access                     = "Allow"
#         protocol                   = "Tcp"
#         destination_port_range     = "443"
#         source_address_prefix      = "*"
#         destination_address_prefix = "*"
#         source_port_range          = "*"
#       }
#     }
#     # role_assignments    = { ... }
#     # diagnostic_settings = { ... }
#     # tags = {}
#   }
# }

# ─── Route Tables ────────────────────────────────────────────

# (Optional) Map of route tables.  Associate to subnets via route_table_key.
# Default: {}
# route_tables = {
#   rt_default = {
#     name               = "rt-default"
#     resource_group_key = "rg_networking"
#     # bgp_route_propagation_enabled = true
#     routes = {
#       to_firewall = {
#         name                   = "to-hub-firewall"
#         address_prefix         = "0.0.0.0/0"
#         next_hop_type          = "VirtualAppliance"
#         next_hop_in_ip_address = "10.0.0.4"
#       }
#     }
#     # role_assignments    = { ... }
#     # diagnostic_settings = { ... }
#     # tags = {}
#   }
# }

# ─── Virtual Networks ───────────────────────────────────────

# (Optional) Map of spoke VNets with subnets, peering, NSG/RT associations.
# Default: {}
# virtual_networks = {
#   vnet_spoke = {
#     name               = "vnet-spoke-shared"
#     address_space      = ["10.1.0.0/16"]
#     resource_group_key = "rg_networking"
#     # location         = "southeastasia"
#     # dns_servers      = ["10.0.0.5"]
#
#     subnets = {
#       snet_app = {
#         name           = "snet-app"
#         address_prefix = "10.1.1.0/24"    # XOR address_prefixes — exactly one
#         # address_prefixes           = ["10.1.1.0/24"]
#         # network_security_group_key = "nsg_app"
#         # route_table_key            = "rt_default"
#         # default_outbound_access_enabled   = false   # default
#         # private_endpoint_network_policies = "Enabled"
#         # role_assignments = { ... }
#       }
#     }
#
#     # peerings = {
#     #   to_hub = {
#     #     name                               = "spoke-to-hub"
#     #     remote_virtual_network_resource_id = "/subscriptions/.../providers/Microsoft.Network/virtualNetworks/vnet-hub"
#     #     allow_forwarded_traffic            = true
#     #     use_remote_gateways                = false
#     #   }
#     # }
#     # role_assignments    = { ... }
#     # diagnostic_settings = { ... }
#     # tags = {}
#   }
# }

# ─── Private DNS Zones ──────────────────────────────────

# (Optional) Create Private DNS Zones and link to pattern VNets.
# PE configurations reference these zone keys via private_dns_zone.keys.
# Default: {}
# private_dns_zones = {
#   dns_blob = {
#     domain_name        = "privatelink.blob.core.windows.net"
#     resource_group_key = "rg_networking"
#     virtual_network_links = {
#       link_to_spoke = {
#         name                = "link-blob-to-spoke"
#         virtual_network_key = "vnet_spoke"
#         # registration_enabled = false
#       }
#     }
#     # role_assignments = { ... }
#     # lock = { kind = "CanNotDelete" }
#     # tags = {}
#   }
# }

# ─── Private DNS Zone Links (BYO) ───────────────────────────

# (Optional) Link existing Private DNS Zones to spoke VNets.
# Default: {}
# byo_private_dns_zone_links = {
#   link_blob = {
#     name                = "link-blob-to-spoke"
#     private_dns_zone_id = "/subscriptions/.../providers/Microsoft.Network/privateDnsZones/privatelink.blob.core.windows.net"
#     virtual_network_key = "vnet_spoke"     # must exist in virtual_networks
#     # registration_enabled = false
#     # resolution_policy    = "Default"
#     # tags = {}
#   }
# }

# ─── Managed Identities ─────────────────────────────────────

# (Optional) User-assigned managed identities.
# Default: {}
# managed_identities = {
#   mi_app = {
#     name               = "mi-shared-services"
#     resource_group_key = "rg_networking"
#     # location = "southeastasia"
#     # tags     = {}
#   }
# }

# ─── Key Vaults ──────────────────────────────────────────────

# (Optional) Map of Key Vaults with RBAC role assignments, private
# endpoints, keys, secrets, and optional random name suffix.
# public_network_access_enabled defaults to false (secure-by-default).
# Default: {}
# key_vaults = {
#   kv_shared = {
#     name               = "kv-shared-svc"
#     resource_group_key = "rg_networking"
#     # sku_name                      = "premium"    # default
#     # public_network_access_enabled = false         # default
#     # purge_protection_enabled      = true          # default
#
#     # name_random_suffix_configuration = {
#     #   length = 4     # appends e.g. "-a1b2" to the name
#     # }
#
#     # keys = {
#     #   cmk_sa = {
#     #     name     = "cmk-storage"
#     #     key_type = "RSA"
#     #     key_size = 2048
#     #     key_opts = ["decrypt", "encrypt", "sign", "unwrapKey", "verify", "wrapKey"]
#     #   }
#     # }
#
#     # role_assignments = {
#     #   kv_reader = {
#     #     role_definition_id_or_name = "Key Vault Secrets User"
#     #     managed_identity_key       = "mi_app"    # XOR principal_id / assign_to_caller
#     #     # principal_id             = "00000000-0000-0000-0000-000000000000"
#     #     # assign_to_caller         = true
#     #   }
#     # }
#
#     # customer_managed_key = {
#     #   key_vault_key = "kv_shared"   # reference by key vault map key
#     #   key_key       = "cmk_sa"      # reference by key map key
#     #   user_assigned_identity = {
#     #     key = "mi_app"              # reference by managed identity map key
#     #   }
#     # }
#
#     # managed_identities = {
#     #   system_assigned    = true
#     #   user_assigned_keys = ["mi_app"]    # resolved from managed_identities variable
#     # }
#
#     # private_endpoints = {
#     #   pe_kv = {
#     #     name = "pe-kv-shared"
#     #     network_configuration = {
#     #       vnet_key   = "vnet_spoke"
#     #       subnet_key = "snet_pe"
#     #     }
#     #     private_dns_zone = {
#     #       keys = ["dns_kv"]
#     #     }
#     #     # role_assignments = { ... }
#     #   }
#     # }
#     # diagnostic_settings = { ... }
#     # lock = { kind = "CanNotDelete" }
#     # tags = {}
#   }
# }

# ─── Storage Accounts ────────────────────────────────────────

# (Optional) Map of storage accounts with private endpoints,
# customer-managed key encryption, managed identities, containers,
# queues, tables, shares, and per-sub-service diagnostic settings.
# Default: {}
# storage_accounts = {
#   sa_shared = {
#     name                          = "sasharedservices"
#     resource_group_key            = "rg_networking"
#     # account_replication_type    = "ZRS"           # default
#     # shared_access_key_enabled   = false           # default (secure)
#     # public_network_access_enabled = false         # default (secure)
#
#     # name_random_suffix_configuration = {
#     #   length = 4     # appends e.g. "a1b2" (no separator for SA names)
#     # }
#
#     # customer_managed_key = {
#     #   key_vault_key = "kv_shared"
#     #   key_key       = "cmk_sa"
#     #   user_assigned_identity = { key = "mi_app" }
#     # }
#
#     # managed_identities = {
#     #   system_assigned    = false
#     #   user_assigned_keys = ["mi_app"]
#     # }
#
#     # containers = {
#     #   logs = { name = "logs" }
#     # }
#
#     # private_endpoints = {
#     #   pe_blob = {
#     #     name             = "pe-blob-shared"
#     #     subresource_name = "blob"
#     #     network_configuration = {
#     #       vnet_key   = "vnet_spoke"
#     #       subnet_key = "snet_pe"
#     #     }
#     #     private_dns_zone = {
#     #       keys = ["dns_blob"]
#     #     }
#     #   }
#     # }
#     # role_assignments    = { ... }
#     # diagnostic_settings = { ... }
#     # tags = {}
#   }
# }

# ─── Standalone Role Assignments ─────────────────────────────

# (Optional) Role assignments at arbitrary scopes (not
# scoped to an AVM-managed resource).
# Default: {}
# role_assignments = {
#   ra_reader = {
#     role_definition_id_or_name = "Reader"
#     scope                      = "/subscriptions/..."
#     managed_identity_key       = "mi_app"  # XOR principal_id / assign_to_caller
#     # principal_id             = "00000000-0000-0000-0000-000000000000"
#     # assign_to_caller         = true
#   }
# }

# ─── vWAN Hub Connections ────────────────────────────────────

# (Optional) Connect spoke VNets to vWAN hubs.
# Default: {}
# vhub_connectivity_definitions = {
#   conn_spoke = {
#     vhub_resource_id = "/subscriptions/.../providers/Microsoft.Network/virtualHubs/vhub-prod"
#     virtual_network = {
#       key = "vnet_spoke"   # XOR id — one must be set
#       # id = "/subscriptions/.../providers/Microsoft.Network/virtualNetworks/..."
#     }
#     # internet_security_enabled = true   # default (routes through hub firewall)
#     # routing = {
#     #   associated_route_table_id = "/subscriptions/.../providers/Microsoft.Network/virtualHubs/vhub-prod/hubRouteTables/defaultRouteTable"
#     #   propagated_route_table = {
#     #     route_table_ids = ["/subscriptions/.../providers/Microsoft.Network/virtualHubs/vhub-prod/hubRouteTables/defaultRouteTable"]
#     #     labels          = ["default"]
#     #   }
#     #   static_vnet_route = {
#     #     name                = "to-onprem"
#     #     address_prefixes    = ["10.0.0.0/8"]
#     #     next_hop_ip_address = "10.1.0.4"
#     #   }
#     # }
#   }
# }

# ─── Bastion Hosts ────────────────────────────────────────────

# (Optional) Map of Azure Bastion Host configurations.
# Empty map = no Bastion hosts deployed.
# For non-Developer SKUs, ip_configuration is required with an
# AzureBastionSubnet (minimum /26).  For Developer SKU, set
# virtual_network instead.
# Default: {}
# bastion_hosts = {
#   bastion_shared = {
#     name               = "bastion-shared"
#     resource_group_key = "rg_networking"
#     # sku              = "Standard"             # default
#     # zones            = ["1", "2", "3"]        # default (zone-redundant)
#
#     ip_configuration = {
#       network_configuration = {
#         subnet_resource_id = "/subscriptions/.../subnets/AzureBastionSubnet"
#       }
#       # create_public_ip = true                 # default
#     }
#
#     # copy_paste_enabled        = true          # default
#     # file_copy_enabled         = false         # default
#     # ip_connect_enabled        = false         # default
#     # tunneling_enabled         = false         # default
#     # private_only_enabled      = false         # default
#     # scale_units               = 2             # default
#     # role_assignments    = { ... }
#     # diagnostic_settings = { ... }
#     # tags = {}
#   }
# }

# ─── Backup Vaults (Azure Data Protection) ───────────────────

# (Optional) Map of Azure Data Protection Backup Vaults for disk,
# blob, AKS, or PostgreSQL backups.  Supports CMK, managed
# identities, backup policies, and backup instances.
# Default: {}
# backup_vaults = {
#   bv_shared = {
#     name               = "bv-shared-services"
#     resource_group_key = "rg_networking"
#     datastore_type     = "VaultStore"
#     redundancy         = "LocallyRedundant"
#     # immutability       = "Disabled"            # default
#     # soft_delete        = "AlwaysOn"             # default
#
#     # managed_identities = {
#     #   system_assigned    = true
#     #   user_assigned_keys = ["mi_app"]
#     # }
#
#     # customer_managed_key = {
#     #   key_vault_key = "kv_shared"
#     #   key_key       = "cmk_bv"
#     #   user_assigned_identity = { key = "mi_app" }
#     # }
#
#     # role_assignments    = { ... }
#     # diagnostic_settings = { ... }
#     # lock = { kind = "CanNotDelete" }
#     # tags = {}
#   }
# }

# ─── Recovery Services Vaults ─────────────────────────────────

# (Optional) Map of Azure Recovery Services Vaults for VM,
# file share, or workload (SQL/SAP HANA) backups.  Supports
# private endpoints, CMK, managed identities, and backup policies.
# Default: {}
# recovery_services_vaults = {
#   rsv_shared = {
#     name                         = "rsv-shared-services"
#     resource_group_key           = "rg_networking"
#     # sku                        = "Standard"           # default
#     # storage_mode_type          = "GeoRedundant"       # default
#     # cross_region_restore_enabled = true                # default
#     # soft_delete_enabled          = true                # default
#
#     # managed_identities = {
#     #   system_assigned    = true
#     #   user_assigned_keys = ["mi_app"]
#     # }
#
#     # customer_managed_key = {
#     #   key_vault_key = "kv_shared"
#     #   key_key       = "cmk_rsv"
#     #   user_assigned_identity = { key = "mi_app" }
#     # }
#
#     # private_endpoints = {
#     #   pe_rsv = {
#     #     name             = "pe-rsv-shared"
#     #     subresource_name = "AzureBackup"
#     #     network_configuration = {
#     #       vnet_key   = "vnet_spoke"
#     #       subnet_key = "snet_pe"
#     #     }
#     #   }
#     # }
#
#     # role_assignments    = { ... }
#     # diagnostic_settings = { ... }
#     # lock = { kind = "CanNotDelete" }
#     # tags = {}
#   }
# }

# ─── Network Watcher / Flow Logs ────────────────────────────

# (Optional) Network Watcher VNet flow logs.  null = no flow logs.
# References an existing Network Watcher (typically auto-created by Azure).
# Default: null
# flowlog_configuration = {
#   network_watcher_id   = "/subscriptions/.../providers/Microsoft.Network/networkWatchers/NetworkWatcher_southeastasia"
#   network_watcher_name = "NetworkWatcher_southeastasia"
#   resource_group_name  = "NetworkWatcherRG"
#   # location           = "southeastasia"     # defaults to var.location
#
#   flow_logs = {
#     vnet_flow = {
#       enabled = true
#       name    = "fl-spoke-vnet"
#       vnet_key = "vnet_spoke"     # resolved to VNet resource ID
#       storage_account = {
#         key = "sa_flowlog"        # XOR resource_id
#       }
#       retention_policy = {
#         enabled = true
#         days    = 90
#       }
#       # traffic_analytics = {
#       #   enabled               = true
#       #   interval_in_minutes   = 10
#       # }
#       # version = 2
#     }
#   }
#   # role_assignments = { ... }
#   # tags = {}
# }
